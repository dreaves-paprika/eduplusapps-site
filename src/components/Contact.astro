---
<section id="contact" class="py-20 md:py-28">
  <div class="max-w-3xl mx-auto px-6">
    <div class="bg-gradient-to-br from-brand-700 to-brand-900 rounded-3xl p-10 md:p-14 text-center shadow-2xl shadow-brand-900/20">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight text-white">
        Get in touch.
      </h2>
      <p class="mt-5 text-lg text-brand-100 max-w-xl mx-auto">
        Questions, feedback, or feature requests? Email goes directly to the developer who built the app — not a support queue.
      </p>

      <a
        href="mailto:support@eduplusapps.com"
        class="mt-8 inline-flex items-center justify-center gap-2 bg-white hover:bg-slate-50 text-brand-900 font-semibold px-7 py-3.5 rounded-full transition shadow-lg"
      >
        support@eduplusapps.com
      </a>

      <div class="mt-10 grid sm:grid-cols-3 gap-3 text-sm text-brand-100 max-w-xl mx-auto">
        <a href="mailto:support@eduplusapps.com" class="bg-white/10 hover:bg-white/20 transition rounded-2xl px-4 py-3 backdrop-blur">
          <div class="font-semibold text-white">Support</div>
          <div class="text-xs">support@</div>
        </a>
        <a href="mailto:privacy@eduplusapps.com" class="bg-white/10 hover:bg-white/20 transition rounded-2xl px-4 py-3 backdrop-blur">
          <div class="font-semibold text-white">Privacy</div>
          <div class="text-xs">privacy@</div>
        </a>
        <a href="mailto:hello@eduplusapps.com" class="bg-white/10 hover:bg-white/20 transition rounded-2xl px-4 py-3 backdrop-blur">
          <div class="font-semibold text-white">General</div>
          <div class="text-xs">hello@</div>
        </a>
      </div>
    </div>
  </div>
</section>
