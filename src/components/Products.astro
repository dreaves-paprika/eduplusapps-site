---
const products = [
  {
    name: 'EDU Mileage+',
    status: 'Coming soon to the App Store',
    statusColor: 'bg-amber-100 text-amber-900',
    tagline: 'Mileage tracking built for K-12 educators and staff.',
    body: 'Automatically log every reimbursable mile between school sites. Multi-district, schedule-aware, audit-ready reports. Built for the way district reimbursement actually works.',
    href: 'https://edumileage.app',
    cta: 'Visit edumileage.app',
    ringClass: 'ring-brand-300 hover:ring-brand-500',
    iconBg: 'from-brand-700 to-brand-900',
  },
  {
    name: 'EDU Audit+',
    status: 'In development',
    statusColor: 'bg-slate-200 text-slate-700',
    tagline: 'Compliance and audit support for school districts.',
    body: "We're building a focused tool for the audit and compliance work that runs in the background of every school district. Details when it's ready.",
    href: 'https://eduaudit.app',
    cta: 'Visit eduaudit.app',
    ringClass: 'ring-slate-200 hover:ring-slate-400',
    iconBg: 'from-slate-600 to-slate-800',
  },
];
---
<section id="products" class="py-20 md:py-28 bg-slate-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mx-auto text-center mb-14">
      <p class="text-sm font-semibold tracking-widest uppercase text-brand-700 mb-3">Apps</p>
      <h2 class="font-display text-4xl md:text-5xl font-bold tracking-tight text-slate-900">
        A small, focused family.
      </h2>
      <p class="mt-5 text-lg text-slate-600">
        Each app is built to do one job exceptionally well — not to be a platform for a hundred. We'd rather ship something tight than something bloated.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {products.map((p) => (
        <a
          href={p.href}
          rel="noopener"
          class={`block bg-white rounded-3xl p-8 ring-1 ${p.ringClass} transition hover:shadow-lg group`}
        >
          <div class="flex items-start justify-between gap-4 mb-5">
            <div class={`w-12 h-12 rounded-2xl bg-gradient-to-br ${p.iconBg} flex items-center justify-center text-white font-display font-bold shadow-md`} aria-hidden="true">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            </div>
            <span class={`text-xs font-bold tracking-wider uppercase px-3 py-1 rounded-full ${p.statusColor}`}>
              {p.status}
            </span>
          </div>

          <h3 class="font-display text-2xl md:text-3xl font-bold tracking-tight text-slate-900 mb-2">
            {p.name}
          </h3>
          <p class="text-base font-medium text-slate-700 mb-4">{p.tagline}</p>
          <p class="text-slate-600 leading-relaxed mb-6">{p.body}</p>

          <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 group-hover:text-brand-900">
            {p.cta}
            <svg class="w-4 h-4 transition group-hover:translate-x-0.5" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
