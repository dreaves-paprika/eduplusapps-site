---
const year = new Date().getFullYear();
---
<footer class="bg-slate-900 text-slate-400 py-14">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-3 gap-10 mb-10">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/icon.png" alt="" class="w-10 h-10 rounded-xl" />
          <span class="font-display font-semibold text-white text-lg">EDU Plus Apps</span>
        </div>
        <p class="text-sm leading-relaxed">
          Focused, privacy-respecting iOS apps for K-12 educators and the staff who keep schools running.
        </p>
      </div>

      <div>
        <h3 class="font-display font-semibold text-white text-sm tracking-wide uppercase mb-4">Apps</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="https://edumileage.app" rel="noopener" class="hover:text-white transition">EDU Mileage+</a></li>
          <li><a href="https://eduaudit.app" rel="noopener" class="hover:text-white transition">EDU Audit+ <span class="text-xs text-slate-500">(in development)</span></a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-display font-semibold text-white text-sm tracking-wide uppercase mb-4">Company</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/support/" class="hover:text-white transition">Support</a></li>
          <li><a href="/privacy/" class="hover:text-white transition">Privacy Policy</a></li>
          <li><a href="mailto:support@eduplusapps.com" class="hover:text-white transition">support@eduplusapps.com</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-slate-800 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-xs">
      <p>© {year} EDU Plus Apps. All rights reserved.</p>
      <p>Built independently. No investors, no analytics, no tracking.</p>
    </div>
  </div>
</footer>
